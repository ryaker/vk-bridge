{
  "name": "vk-bridge",
  "version": "0.1.0",
  "description": "Universal agent tracking layer for Vibe Kanban",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "vkb": "dist/cli/index.js"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "install-hooks": "bash hooks/install.sh",
    "install-vkb": "npm run build && npm link"
  },
  "dependencies": {
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsx": "^4.0.0",
    "@types/node": "^22.0.0"
  }
}
